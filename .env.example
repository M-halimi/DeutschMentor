# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Used only as fallback when request headers are unavailable (scripts, cron).
# At runtime the app auto-detects the current origin from request headers,
# so mobile/LAN access works without changing this value.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Management API (for scripts that run raw SQL)
SUPABASE_ACCESS_TOKEN=your-supabase-management-access-token
SUPABASE_PROJECT_REF=your-project-ref

# AI Providers
GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key
